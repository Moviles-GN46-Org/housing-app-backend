generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String                @id @default(uuid())
  email                String                @unique
  passwordHash         String?
  firstName            String
  lastName             String
  phone                String?
  role                 UserRole
  authProvider         AuthProvider          @default(EMAIL)
  profilePictureUrl    String?
  isActive             Boolean               @default(true)
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  analyticsEvents      AnalyticsEvent[]
  chatParticipations   ChatParticipant[]
  Favorite             Favorite[]
  landlordVerification LandlordVerification?

  // Relations
  properties         Property[]         // Landlord's listings
  reviewsWritten     Review[]           @relation("ReviewAuthor")
  reviewsReceived    Review[]           @relation("ReviewedLandlord")
  sentMessages       Message[]          @relation("MessageSender")
  chatParticipations ChatParticipant[]
  reports            Report[]           @relation("ReportAuthor")
  reportsReceived    Report[]           @relation("ReportedUser")
  roommateProfile    RoommateProfile?
  swipesMade         RoommateSwipe[]    @relation("Swiper")
  swipesReceived     RoommateSwipe[]    @relation("Swiped")
  analyticsEvents    AnalyticsEvent[]
  searchEvents       SearchEvent[]
  notifications      Notification[]
  favorites          Favorite[]
  studentVerification  StudentVerification?

  @@index([role])
  @@index([email])
}

model University {
  id              String   @id @default(uuid())
  name            String
  normalizedName  String   @unique
  aliases         Json     @default("[]")
  city            String?
  latitude        Float
  longitude       Float
  defaultRadiusKm Float    @default(2)
  isDefault       Boolean  @default(false)
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @default(now()) @updatedAt

  @@index([isActive])
  @@index([isDefault])
}

model StudentVerification {
  id               String             @id @default(uuid())
  userId           String             @unique
  universityEmail  String             @unique
  verificationCode String
  codeExpiresAt    DateTime
  status           VerificationStatus @default(UNVERIFIED)
  verifiedAt       DateTime?
  createdAt        DateTime           @default(now())
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model LandlordVerification {
  id              String             @id @default(uuid())
  userId          String             @unique
  idDocumentUrl   String
  utilityBillUrl  String
  status          VerificationStatus @default(PENDING)
  reviewedBy      String?
  rejectionReason String?
  reviewedAt      DateTime?
  createdAt       DateTime           @default(now())
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Property {
  id                String         @id @default(uuid())
  landlordId        String
  title             String
  description       String
  propertyType      PropertyType
  status            PropertyStatus @default(ACTIVE)
  monthlyRent       Decimal        @db.Decimal(10, 2)
  depositAmount     Decimal?       @db.Decimal(10, 2)
  includesUtilities Boolean        @default(false)
  address           String
  neighborhood      String
  city              String         @default("Bogotá")
  latitude          Float
  longitude         Float
  sizeM2            Float?
  bedrooms          Int
  bathrooms         Int
  furnished         Boolean        @default(false)
  petFriendly       Boolean        @default(false)
  hasParking        Boolean        @default(false)
  hasLaundry        Boolean        @default(false)
  hasWifi           Boolean        @default(false)
  imageUrls         Json           @default("[]")
  publishedAt       DateTime       @default(now())
  lastActiveAt      DateTime       @default(now())
  expirationNotice  DateTime?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  chats             Chat[]
  Favorite          Favorite[]
  landlord          User           @relation(fields: [landlordId], references: [id], onDelete: Cascade)
  reports           Report[]
  favorites         Favorite[]
  reviews           Review[]

  @@index([status])
  @@index([landlordId])
  @@index([neighborhood])
  @@index([monthlyRent])
  @@index([latitude, longitude])
}

model Review {
  id         String   @id @default(uuid())
  propertyId String
  authorId   String
  landlordId String
  rating     Int
  comment    String
  isVisible  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  author     User     @relation("ReviewAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  landlord   User     @relation("ReviewedLandlord", fields: [landlordId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([propertyId, authorId])
  @@index([propertyId])
  @@index([landlordId])
}

model Chat {
  id           String            @id @default(uuid())
  propertyId   String?
  status       ChatStatus        @default(ACTIVE)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  property     Property?         @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  participants ChatParticipant[]
  messages     Message[]
  visits       Visit[]

  @@index([propertyId])
}

model ChatParticipant {
  id       String   @id @default(uuid())
  chatId   String
  userId   String
  joinedAt DateTime @default(now())
  chat     Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([chatId, userId])
  @@index([userId])
}

model Message {
  id        String      @id @default(uuid())
  chatId    String
  senderId  String
  type      MessageType @default(TEXT)
  content   String
  metadata  Json?
  isRead    Boolean     @default(false)
  createdAt DateTime    @default(now())
  chat      Chat        @relation(fields: [chatId], references: [id], onDelete: Cascade)
  sender    User        @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([chatId, createdAt])
  @@index([senderId])
}

model Visit {
  id          String      @id @default(uuid())
  chatId      String
  propertyId  String
  studentId   String
  landlordId  String
  scheduledAt DateTime
  status      VisitStatus @default(CONFIRMED)
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  chat        Chat        @relation(fields: [chatId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([landlordId])
  @@index([scheduledAt])
}

model Report {
  id             String       @id @default(uuid())
  reporterId     String
  reportedUserId String?
  propertyId     String?
  reason         ReportReason
  description    String?
  status         ReportStatus @default(PENDING)
  resolvedBy     String?
  resolution     String?
  createdAt      DateTime     @default(now())
  resolvedAt     DateTime?
  property       Property?    @relation(fields: [propertyId], references: [id])
  reportedUser   User?        @relation("ReportedUser", fields: [reportedUserId], references: [id])
  reporter       User         @relation("ReportAuthor", fields: [reporterId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([propertyId])
}

model RoommateProfile {
  id               String           @id @default(uuid())
  userId           String           @unique
  sleepSchedule    SleepSchedule
  cleanlinessLevel CleanlinessLevel
  noisePreference  NoisePreference
  smokes           Boolean          @default(false)
  hasPets          Boolean          @default(false)
  budgetMin        Decimal          @db.Decimal(10, 2)
  budgetMax        Decimal          @db.Decimal(10, 2)
  preferredArea    String?
  bio              String?
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  birthDate        DateTime?
  job              String?
  university       String?
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model RoommateSwipe {
  id        String         @id @default(uuid())
  swiperId  String
  swipedId  String
  direction SwipeDirection
  createdAt DateTime       @default(now())
  swiped    User           @relation("Swiped", fields: [swipedId], references: [id], onDelete: Cascade)
  swiper    User           @relation("Swiper", fields: [swiperId], references: [id], onDelete: Cascade)

  @@unique([swiperId, swipedId])
  @@index([swipedId])
}

model RoommateMatch {
  id        String   @id @default(uuid())
  user1Id   String
  user2Id   String
  chatId    String?
  createdAt DateTime @default(now())

  @@unique([user1Id, user2Id])
  @@index([user1Id])
  @@index([user2Id])
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

model AnalyticsEvent {
  id         String             @id @default(uuid())
  userId     String?
  sessionId  String
  eventType  AnalyticsEventType
  payload    Json
  screenName String?
  timestamp  DateTime           @default(now())
  user       User?              @relation(fields: [userId], references: [id])

  @@index([eventType])
  @@index([sessionId])
  @@index([timestamp])
  @@index([userId])
  @@index([screenName])
}

model SearchEvent {
  id            String            @id @default(uuid())
  userId        String?
  sessionId     String
  query         String?
  city          String
  neighborhood  String?
  canonicalZone String
  lat           Float?
  lng           Float?
  radiusKm      Float?
  filters       Json?
  filtersHash   String
  source        SearchEventSource
  searchedAt    DateTime          @default(now())
  createdAt     DateTime          @default(now())
  user          User?             @relation(fields: [userId], references: [id])

  @@index([searchedAt])
  @@index([city, canonicalZone])
  @@index([city, canonicalZone, searchedAt])
  @@index([sessionId, searchedAt])
  @@index([userId, searchedAt])
  @@index([filtersHash])
}

model Favorite {
  id         String   @id
  userId     String
  propertyId String
  createdAt  DateTime @default(now())
  Property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  User       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@index([createdAt])
  @@index([propertyId])
  @@index([userId])
}

enum UserRole {
  STUDENT
  LANDLORD
  ADMIN
}

enum AuthProvider {
  EMAIL
  GOOGLE
  FACEBOOK
}

enum VerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum PropertyType {
  APARTMENT
  ROOM
  STUDIO
  HOUSE
  SHARED_ROOM
}

enum PropertyStatus {
  ACTIVE
  RENTED
  HIDDEN
  EXPIRED
}

enum ChatStatus {
  ACTIVE
  ARCHIVED
  BLOCKED
}

enum MessageType {
  TEXT
  VISIT_PROPOSAL
  VISIT_RESPONSE
  SYSTEM
}

enum VisitStatus {
  CONFIRMED
  COMPLETED
  CANCELLED_BY_STUDENT
  CANCELLED_BY_LANDLORD
  NO_SHOW
}

enum ReportReason {
  ASKS_MONEY_OUTSIDE_APP
  FAKE_LISTING
  HARASSMENT
  INAPPROPRIATE_CONTENT
  SCAM_SUSPICION
  OTHER
}

enum ReportStatus {
  PENDING
  UNDER_REVIEW
  RESOLVED_REMOVED
  RESOLVED_WARNING
  RESOLVED_DISMISSED
}

enum SleepSchedule {
  EARLY_BIRD
  NIGHT_OWL
  FLEXIBLE
}

enum CleanlinessLevel {
  VERY_TIDY
  MODERATE
  RELAXED
}

enum NoisePreference {
  QUIET
  MODERATE
  LIVELY
}

enum SwipeDirection {
  RIGHT
  LEFT
}

// ============================================================
// 9. FAVORITES SYSTEM (User's saved properties)
// ============================================================

model Favorite {
  id          String   @id @default(uuid())
  userId      String
  propertyId  String
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property    Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId]) // One favorite per user per property
  @@index([userId])
  @@index([propertyId])
  @@index([createdAt])
}

// ============================================================
// 10. NOTIFICATIONS
// ============================================================

enum NotificationType {
  NEW_MESSAGE
  VISIT_REMINDER
  VISIT_CONFIRMED
  VISIT_CANCELLED
  ROOMMATE_MATCH
  REVIEW_RECEIVED
  LISTING_EXPIRING
  REPORT_RESOLVED
  VERIFICATION_APPROVED
  VERIFICATION_REJECTED
  PROPERTY_MATCH
}

model Notification {
  id          String           @id @default(uuid())
  userId      String
  type        NotificationType
  title       String
  body        String
  data        Json?            // Additional context (propertyId, chatId, etc.)
  isRead      Boolean          @default(false)
  createdAt   DateTime         @default(now())

  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt])
}

// ============================================================
// 11. ANALYTICS EVENTS (Generic event store)
// ============================================================
// Single table approach - flexible JSON payload per event type
//
// Event types and their expected payloads:
//
// SESSION_START:    { device, os, appVersion }
// SESSION_END:      { durationSeconds }
// SEARCH:           { filters: { petFriendly, maxPrice, ... }, resultsCount }
// PROPERTY_VIEW:    { propertyId, source: "map"|"list"|"search" }
// FILTER_APPLIED:   { filterName, filterValue }
// FEATURE_CLICK:    { feature: "roommate_finder"|"chat"|"reviews"|... }
// MAP_INTERACTION:  { action: "zoom"|"pan"|"search_area", location }
// CHAT_STARTED:     { propertyId, landlordId }
// REVIEW_SUBMITTED: { propertyId, rating }
// VISIT_SCHEDULED:  { propertyId, chatId }
// CRASH:            { screen, errorMessage, stackTrace }

enum AnalyticsEventType {
  SESSION_START
  SESSION_END
  SEARCH
  PROPERTY_VIEW
  FILTER_APPLIED
  FEATURE_CLICK
  MAP_INTERACTION
  CHAT_STARTED
  REVIEW_SUBMITTED
  VISIT_SCHEDULED
  CRASH
  SUPPLY_DENSITY_CHECK
  LOCATION_STATS_UPDATE  
  SESSION_EVENT         
}

enum SearchEventSource {
  house_list
  map
}
